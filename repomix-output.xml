<file path="src/styles/globals.css">
@tailwind base;
@tailwind components;
@tailwind utilities;

@layer base {
  :root {
    --violet-dim: rgba(255, 255, 255, 0.08);
    --amber-dim:  rgba(255, 255, 255, 0.05);
  }

  /* Lenis drives smooth scroll — native smooth-behavior must be off */
  html.lenis, html.lenis body { height: auto; }
  .lenis.lenis-smooth { scroll-behavior: auto !important; }
  .lenis.lenis-smooth [data-lenis-prevent] { overscroll-behavior: contain; }
  .lenis.lenis-stopped { overflow: hidden; }

  body {
    @apply bg-bg text-ink antialiased;
    font-family: var(--font-inter), sans-serif;
  }

  h1, h2, h3, h4 {
    font-family: var(--font-bricolage), sans-serif;
  }

  ::selection {
    background: rgba(255, 255, 255, 0.2);
    color: #0a0a0a;
  }

  * { scrollbar-width: thin; scrollbar-color: rgba(255,255,255,0.18) transparent; }
  *::-webkit-scrollbar { width: 4px; }
  *::-webkit-scrollbar-track { background: transparent; }
  *::-webkit-scrollbar-thumb { background: rgba(255,255,255,0.18); border-radius: 99px; }
}

@layer components {
  /* ── Buttons ── */
  .btn-primary {
    @apply inline-block font-display font-semibold text-[15px] px-8 py-3.5
           bg-ink text-bg rounded-full
           transition-all duration-200
           hover:-translate-y-0.5 hover:shadow-[0_16px_40px_rgba(255,255,255,0.15)];
  }

  .btn-ghost {
    @apply inline-block font-display font-medium text-[15px] px-8 py-3.5
           bg-transparent text-muted rounded-full
           border border-white/[0.09]
           transition-all duration-200
           hover:text-ink hover:border-white/20;
  }

  .btn-sm {
    @apply inline-flex items-center gap-1.5 font-display font-medium text-[13px]
           px-5 py-2 bg-transparent text-muted rounded-full
           border border-white/[0.09]
           transition-all duration-200
           hover:text-ink hover:border-white/20;
  }

  /* ── Cards ── */
  .card {
    @apply bg-surface border border-white/[0.05] rounded-card
           transition-all duration-300
           hover:border-violet/20 hover:-translate-y-1;
  }

  /* ── Section label ── */
  .section-label {
    @apply block text-[11px] font-semibold tracking-[0.1em] uppercase text-violet-soft mb-4;
  }

  /* ── Tag pills ── */
  .tag {
    @apply text-[11px] font-medium px-3 py-1 rounded-full
           bg-[rgba(255,255,255,0.08)] text-violet-soft
           border border-[rgba(255,255,255,0.12)];
  }
  .tag-amber {
    @apply text-[11px] font-medium px-3 py-1 rounded-full
           bg-[rgba(255,255,255,0.06)] text-amber
           border border-[rgba(255,255,255,0.1)];
  }
  .tag-teal {
    @apply text-[11px] font-medium px-3 py-1 rounded-full
           bg-[rgba(255,255,255,0.06)] text-teal
           border border-[rgba(255,255,255,0.1)];
  }

  /* ── Stack pill ── */
  .stack-pill {
    @apply text-[11px] font-medium px-2.5 py-1 rounded-[6px]
           bg-surface2 text-muted border border-white/[0.05];
  }

  /* ── Page hero ── */
  .page-hero-label {
    @apply block text-[11px] font-semibold tracking-[0.12em] uppercase text-violet-soft mb-5;
  }

  .page-hero-title {
    @apply font-display font-bold leading-[0.95] tracking-[-0.05em]
           text-[clamp(3rem,8vw,6rem)];
  }

  .outline-text {
    color: transparent;
    -webkit-text-stroke: 1.5px rgba(255,255,255,0.2);
  }
}

/* ── Framer Motion reveal helper ── */
.will-reveal {
  will-change: opacity, transform;
}

/* ── Skill bar ── */
.skill-bar-fill {
  @apply h-full rounded-full bg-gradient-to-r from-violet-soft to-ink;
  transition: width 1s cubic-bezier(0.16, 1, 0.3, 1);
}
.skill-bar-fill-amber {
  @apply h-full rounded-full bg-gradient-to-r from-muted to-violet-soft;
  transition: width 1s cubic-bezier(0.16, 1, 0.3, 1);
}
